# Copy this file to .env and fill in real values. Never commit .env.

# MySQL connection string (Aiven/RDS/local, etc.)
DATABASE_URL="mysql://user:password@host:3306/bnwems"

# --- App config ---
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Internal secret used to sign/verify JWTs — generate your own, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-random-64-char-hex-string
JWT_EXPIRES_IN=7d

# Firebase Admin SDK — shared by Storage (evidences upload) AND Cloud Messaging (push
# notifications, src/modules/shared/notification.*). From Firebase Console > Project settings >
# Service accounts > Generate new private key (downloads a JSON file with these 3 fields).
# FIREBASE_PRIVATE_KEY: paste the JSON's "private_key" value as ONE line — keep the \n escapes
# literal (don't turn them into real newlines), the app unescapes them at runtime.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# Company bank account for receiving deposits/settlements (GET /settings/bank-account)
COMPANY_BANK_BIN=
COMPANY_BANK_NAME=
COMPANY_BANK_ACCOUNT_NUMBER=
COMPANY_BANK_ACCOUNT_NAME=

# SMTP (Gmail App Password) — used to invite employees & reset passwords by email.
# Create an App Password at https://myaccount.google.com/apppasswords (requires 2FA enabled).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
